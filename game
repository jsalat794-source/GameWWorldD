<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Игра Мемори</title>
</head>
<body bgcolor="#2c3e50" text="white" style="font-family: Arial, sans-serif;">

    <center>
        <h1>Игра Мемори</h1>
        <p>Найди все парные карточки! Ошибок: <span id="errors">0</span></p>

        <!-- Игровое поле (таблица) -->
        <table id="grid" border="0" cellpadding="5" style="margin: 20px auto;">
            <!-- Сюда JavaScript сам добавит карточки -->
        </table>
        
        <br>
        
        <!-- Кнопка перезапуска игры -->
        <button onclick="initGame()" style="padding: 10px 20px; border-radius: 10px; cursor: pointer; font-size: 16px; margin-right: 10px;">
            🔄 Начать заново
        </button>

        <!-- Работающая кнопка возврата в меню -->
        <a href="index.html">
            <button style="padding: 10px 20px; border-radius: 10px; cursor: pointer; font-size: 16px;">
                ← Вернуться в меню
            </button>
        </a>
    </center>

    <script>
        // Набор картинок-эмодзи (12 пар = 24 карточки)
        const icons = ['🍎', '🍏', '🍌', '🍉', '🍇', '🍓', '🐱', '🐶', '🦁', '🦊', '⚽', '🏀'];
        let cards = [];
        let flippedCards = [];
        let lockBoard = false;
        let errorCount = 0;

        // Функция запуска и перезапуска игры
        function initGame() {
            const grid = document.getElementById('grid');
            grid.innerHTML = ''; // Очищаем поле
            flippedCards = [];
            lockBoard = false;
            errorCount = 0;
            document.getElementById('errors').innerText = errorCount;

            // Удваиваем массив, чтобы получить пары
            cards = [...icons, ...icons];

            // СЛУЧАЙНОЕ ПЕРЕМЕШИВАНИЕ (каждый раз разный порядок)
            cards.sort(() => Math.random() - 0.5);

            // Создаем сетку 6 столбиков на 4 строчки
            let cardIndex = 0;
            for (let i = 0; i < 4; i++) {
                let row = grid.insertRow();
                for (let j = 0; j < 6; j++) {
                    let cell = row.insertCell();
                    
                    // Создаем визуальную карточку
                    let card = document.createElement('div');
                    card.style.width = '70px';
                    card.style.height = '70px';
                    card.style.backgroundColor = '#34495e';
                    card.style.border = '3px solid #3498db';
                    card.style.borderRadius = '10px';
                    card.style.display = 'flex';
                    card.style.justifyContent = 'center';
                    card.style.alignItems = 'center';
                    card.style.fontSize = '32px';
                    card.style.cursor = 'pointer';
                    card.style.userSelect = 'none';
                    
                    // Записываем внутрь карточки её секретный символ
                    card.dataset.icon = cards[cardIndex];
                    card.innerText = '❓'; // Рубашка карты

                    // Навешиваем клик
                    card.addEventListener('click', flipCard);
                    
                    cell.appendChild(card);
                    cardIndex++;
                }
            }
        }

        // Логика переворота карточки
        function flipCard() {
            if (lockBoard) return; // Если идет анимация проверки, кликать нельзя
            if (this === flippedCards[0]) return; // Нельзя кликнуть на ту же карту второй раз
            if (this.innerText !== '❓') return; // Если карта уже угадана, ничего не делаем

            // Показываем символ карточки
            this.innerText = this.dataset.icon;
            this.style.backgroundColor = '#ecf0f1';
            flippedCards.push(this);

            // Если перевернули две карты — проверяем их
            if (flippedCards.length === 2) {
                checkMatch();
            }
        }

        // Проверка на совпадение
        function checkMatch() {
            let isMatch = flippedCards[0].dataset.icon === flippedCards[1].dataset.icon;

            if (isMatch) {
                // Карты совпали — оставляем открытыми
                flippedCards[0].style.border = '3px solid #2ecc71';
                flippedCards[1].style.border = '3px solid #2ecc71';
                flippedCards = [];
                checkWin();
            } else {
                // Карты не совпали — закрываем обратно через 0.8 секунды
                lockBoard = true;
                errorCount++;
                document.getElementById('errors').innerText = errorCount;

                setTimeout(() => {
                    flippedCards[0].innerText = '❓';
                    flippedCards[0].style.backgroundColor = '#34495e';
                    flippedCards[1].innerText = '❓';
                    flippedCards[1].style.backgroundColor = '#34495e';
                    
                    flippedCards = [];
                    lockBoard = false;
                }, 800);
            }
        }

        // Проверка на победу
        function checkWin() {
            // Если на поле больше нет закрытых карточек (вопросиков)
            const allCards = document.querySelectorAll('#grid div');
            const hiddenCards = Array.from(allCards).filter(c => c.innerText === '❓');
            
            if (hiddenCards.length === 0) {
                setTimeout(() => {
                    alert(`Победа! Вы нашли все пары. Ошибок сделано: ${errorCount}`);
                }, 200);
            }
        }

        // Запуск игры при открытии страницы
        initGame();
    </script>
</body>
</html>

