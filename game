<!DOCTYPE html>
<html>
<head>
    <title>Змейка</title>
    <style>
        /* Центрируем игру на странице */
        body { display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #222; color: white; flex-direction: column; font-family: Arial; }
        canvas { border: 5px solid #fff; background: #000; }
    </style>
</head>
<body>

    <h1>Змейка</h1>
    <canvas id="game" width="400" height="400"></canvas>

    <script>
        const canvas = document.getElementById("game");
        const ctx = canvas.getContext("2d");

        let box = 20; // Размер одной клетки
        let snake = [{x: 10 * box, y: 10 * box}]; // Начальная позиция змейки
        let food = { x: Math.floor(Math.random() * 20) * box, y: Math.floor(Math.random() * 20) * box };
        let dir; // Направление

        // Слушаем нажатия клавиш
        document.addEventListener("keydown", event => {
            if(event.keyCode == 37 && dir != "right") dir = "left";
            else if(event.keyCode == 38 && dir != "down") dir = "up";
            else if(event.keyCode == 39 && dir != "left") dir = "right";
            else if(event.keyCode == 40 && dir != "up") dir = "down";
        });

        function draw() {
            ctx.fillStyle = "black";
            ctx.fillRect(0, 0, canvas.width, canvas.height); // Чистим поле

            // Рисуем еду
            ctx.fillStyle = "red";
            ctx.fillRect(food.x, food.y, box, box);

            // Рисуем змейку
            for(let i = 0; i < snake.length; i++) {
                ctx.fillStyle = (i == 0) ? "green" : "lime";
                ctx.fillRect(snake[i].x, snake[i].y, box, box);
            }

            // Движение
            let snakeX = snake[0].x;
            let snakeY = snake[0].y;

            if(dir == "left") snakeX -= box;
            if(dir == "right") snakeX += box;
            if(dir == "up") snakeY -= box;
            if(dir == "down") snakeY += box;

            // Если змейка съела еду
            if(snakeX == food.x && snakeY == food.y) {
                food = { x: Math.floor(Math.random() * 20) * box, y: Math.floor(Math.random() * 20) * box };
            } else {
                snake.pop(); // Удаляем хвост, если не поели
            }

            let newHead = { x: snakeX, y: snakeY };

            // Проигрыш (столкновение со стеной или собой)
            if(snakeX < 0 || snakeX >= canvas.width || snakeY < 0 || snakeY >= canvas.height || snake.some(s => s.x === newHead.x && s.y === newHead.y)) {
                clearInterval(game);
                alert("Игра окончена!");
                location.reload(); // Перезагрузка страницы
            }

            snake.unshift(newHead); // Добавляем новую голову
        }

        let game = setInterval(draw, 100); // Запуск цикла игры (100 мс)
    </script>
</body>
</html>
